# Production secrets and runtime configuration
SCM_ENVIRONMENT=production
SCM_DEBUG=false
SCM_SECRET_KEY=replace-with-a-long-random-secret
SCM_HOST=0.0.0.0
SCM_PORT=5000
SCM_SESSION_COOKIE_SECURE=false
SCM_SESSION_TTL_SECONDS=3600

# Use an absolute or project-relative path. On ephemeral cloud disks,
# configure these to a mounted persistent volume when durable files are required.
# SCM_STORAGE_ROOT=/var/lib/smartcrowd
# SCM_MODEL_PATH=/var/lib/smartcrowd/models/yolov8n.pt

SCM_MAX_UPLOAD_BYTES=1073741824
SCM_MAX_CAMERAS=8
SCM_TARGET_INFERENCE_FPS=12
